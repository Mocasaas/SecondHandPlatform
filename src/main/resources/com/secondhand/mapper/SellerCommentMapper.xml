<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.secondhand.mapper.SellerCommentMapper">

    <resultMap id="SellerCommentResultMap" type="com.secondhand.pojo.SellerComment">
        <id column="id" property="id"/>
        <result column="order_id" property="orderId"/>
        <result column="seller_id" property="sellerId"/>
        <result column="buyer_id" property="buyerId"/>
        <result column="rating" property="rating"/>
        <result column="content" property="content"/>
        <result column="create_time" property="createTime"/>
        <association property="seller" javaType="com.secondhand.pojo.User">
            <id column="s_id" property="id"/>
            <result column="s_username" property="username"/>
        </association>
        <association property="buyer" javaType="com.secondhand.pojo.User">
            <id column="b_id" property="id"/>
            <result column="b_username" property="username"/>
        </association>
    </resultMap>

    <insert id="insert" parameterType="com.secondhand.pojo.SellerComment" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO seller_comment (order_id, seller_id, buyer_id, rating, content)
        VALUES (#{orderId}, #{sellerId}, #{buyerId}, #{rating}, #{content})
    </insert>

    <select id="selectBySellerId" resultMap="SellerCommentResultMap">
        SELECT sc.*,
               s.id AS s_id, s.username AS s_username,
               b.id AS b_id, b.username AS b_username
        FROM seller_comment sc
                 LEFT JOIN user s ON sc.seller_id = s.id
                 LEFT JOIN user b ON sc.buyer_id = b.id
        WHERE sc.seller_id = #{sellerId}
        ORDER BY sc.create_time DESC
    </select>

    <select id="selectByBuyerId" resultMap="SellerCommentResultMap">
        SELECT sc.*,
               s.id AS s_id, s.username AS s_username,
               b.id AS b_id, b.username AS b_username
        FROM seller_comment sc
                 LEFT JOIN user s ON sc.seller_id = s.id
                 LEFT JOIN user b ON sc.buyer_id = b.id
        WHERE sc.buyer_id = #{buyerId}
        ORDER BY sc.create_time DESC
    </select>

    <select id="selectByOrderId" resultMap="SellerCommentResultMap">
        SELECT * FROM seller_comment WHERE order_id = #{orderId}
    </select>

    <select id="avgRatingBySellerId" resultType="double">
        SELECT COALESCE(AVG(rating), 0) FROM seller_comment WHERE seller_id = #{sellerId}
    </select>

</mapper>